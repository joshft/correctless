+    "$DRIFT_DEBT_FILE" > "$DRIFT_DEBT_FILE.$$" && mv "$DRIFT_DEBT_FILE.$$" "$DRIFT_DEBT_FILE"); then
+    rm -f "$DRIFT_DEBT_FILE.$$"
+    trap - EXIT
+    die "Failed to write drift debt file"
+  fi
   trap - EXIT

   info "Drift item $drift_id marked as resolved: $reason"
