diff --git a/correctless/hooks/workflow-advance.sh b/correctless/hooks/workflow-advance.sh
index a23de02..4a7b04a 100755
--- a/correctless/hooks/workflow-advance.sh
+++ b/correctless/hooks/workflow-advance.sh
@@ -530,12 +530,13 @@ cmd_qa() {
     eval "$cov_cmd" > "$ARTIFACTS_DIR/coverage-baseline-$(branch_slug).out" 2>&1 || true
   fi

-  # Increment QA round counter and transition phase in a single write
-  local state
-  state="$(read_state)"
-  state="$(echo "$state" | jq --arg t "$(date -u +%FT%TZ)" \
