{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|CreateFile|Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/workflow-gate.sh",
            "timeout_ms": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|CreateFile|Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/audit-trail.sh",
            "timeout_ms": 1000
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/token-tracking.sh",
            "timeout_ms": 1000
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(.claude/hooks/workflow-advance.sh *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/hooks/statusline.sh"
  }
}
