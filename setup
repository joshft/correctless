#!/usr/bin/env bash
# Correctless — install script
# Auto-detects project language, test runner, and tools.
# Registers hooks, creates templates, generates config.
# Supports both Lite and Full modes.
# Idempotent — re-running never overwrites user-edited files.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

info()  { echo "  $*"; }
ok()    { echo "  ✓ $*"; }
skip()  { echo "  - $* (already exists)"; }
warn()  { echo "  ! $*"; }

# ---------------------------------------------------------------------------
# Detect project language
# ---------------------------------------------------------------------------

detect_language() {
  if [ -f "$REPO_ROOT/go.mod" ]; then
    echo "go"
  elif [ -f "$REPO_ROOT/package.json" ]; then
    echo "typescript"
  elif [ -f "$REPO_ROOT/Cargo.toml" ]; then
    echo "rust"
  elif [ -f "$REPO_ROOT/pyproject.toml" ] || [ -f "$REPO_ROOT/requirements.txt" ] || [ -f "$REPO_ROOT/setup.py" ]; then
    echo "python"
  elif [ -f "$REPO_ROOT/pom.xml" ] || [ -f "$REPO_ROOT/build.gradle" ]; then
    echo "java"
  else
    echo "other"
  fi
}

# ---------------------------------------------------------------------------
# Detect commands and patterns per language
# ---------------------------------------------------------------------------

detect_config() {
  local lang="$1"
  local name
  name="$(basename "$REPO_ROOT")"

  case "$lang" in
    go)
      cat <<GOEOF
{
  "project": {
    "name": "$name",
    "language": "go",
    "description": ""
  },
  "commands": {
    "test": "go test ./...",
    "test_verbose": "go test -v ./...",
    "coverage": "go test -coverprofile=coverage.out ./...",
    "lint": "go vet ./...",
    "build": "go build ./..."
  },
  "patterns": {
    "test_file": "*_test.go",
    "source_file": "*.go",
    "test_fail_pattern": "FAIL",
    "build_error_pattern": "cannot|undefined|syntax error"
  },
  "is_monorepo": false,
  "packages": {},
  "workflow": {
    "min_qa_rounds": 1,
    "require_review": true,
    "auto_update_antipatterns": true,
    "git_trailers": false,
    "git_notes": false
  },
  "paths": {
    "architecture_doc": "ARCHITECTURE.md",
    "agent_context": "AGENT_CONTEXT.md",
    "antipatterns": ".claude/antipatterns.md",
    "docs": "docs/",
    "specs": "docs/specs/",
    "artifacts": ".claude/artifacts/",
    "state": ".claude/artifacts/workflow-state-{branch-slug}.json"
  }
}
GOEOF
      ;;
    typescript)
      # Detect package manager and test runner
      local test_cmd="npm test"
      local test_verbose="npm test -- --verbose"
      local coverage="npm test -- --coverage"
      local lint="npm run lint"
      local build="npm run build"

      if [ -f "$REPO_ROOT/pnpm-lock.yaml" ]; then
        test_cmd="pnpm test"
        test_verbose="pnpm test -- --verbose"
        coverage="pnpm test -- --coverage"
        lint="pnpm run lint"
        build="pnpm run build"
      elif [ -f "$REPO_ROOT/yarn.lock" ]; then
        test_cmd="yarn test"
        test_verbose="yarn test --verbose"
        coverage="yarn test --coverage"
        lint="yarn lint"
        build="yarn build"
      fi

      cat <<TSEOF
{
  "project": {
    "name": "$name",
    "language": "typescript",
    "description": ""
  },
  "commands": {
    "test": "$test_cmd",
    "test_verbose": "$test_verbose",
    "coverage": "$coverage",
    "lint": "$lint",
    "build": "$build"
  },
  "patterns": {
    "test_file": "*.test.ts|*.test.tsx|*.spec.ts|*.spec.tsx",
    "source_file": "*.ts|*.tsx",
    "test_fail_pattern": "FAIL|failing",
    "build_error_pattern": "error TS|Cannot find|SyntaxError"
  },
  "is_monorepo": false,
  "packages": {},
  "workflow": {
    "min_qa_rounds": 1,
    "require_review": true,
    "auto_update_antipatterns": true,
    "git_trailers": false,
    "git_notes": false
  },
  "paths": {
    "architecture_doc": "ARCHITECTURE.md",
    "agent_context": "AGENT_CONTEXT.md",
    "antipatterns": ".claude/antipatterns.md",
    "docs": "docs/",
    "specs": "docs/specs/",
    "artifacts": ".claude/artifacts/",
    "state": ".claude/artifacts/workflow-state-{branch-slug}.json"
  }
}
TSEOF
      ;;
    python)
      local test_cmd="pytest"
      local coverage="pytest --cov"
      local lint="ruff check ."
      if [ -f "$REPO_ROOT/.flake8" ] || grep -q 'flake8' "$REPO_ROOT/pyproject.toml" 2>/dev/null; then lint="flake8 ."; fi

      cat <<PYEOF
{
  "project": {
    "name": "$name",
    "language": "python",
    "description": ""
  },
  "commands": {
    "test": "$test_cmd",
    "test_verbose": "pytest -v",
    "coverage": "$coverage",
    "lint": "$lint",
    "build": ""
  },
  "patterns": {
    "test_file": "test_*.py|*_test.py",
    "source_file": "*.py",
    "test_fail_pattern": "FAILED|ERROR",
    "build_error_pattern": "SyntaxError|ImportError"
  },
  "is_monorepo": false,
  "packages": {},
  "workflow": {
    "min_qa_rounds": 1,
    "require_review": true,
    "auto_update_antipatterns": true,
    "git_trailers": false,
    "git_notes": false
  },
  "paths": {
    "architecture_doc": "ARCHITECTURE.md",
    "agent_context": "AGENT_CONTEXT.md",
    "antipatterns": ".claude/antipatterns.md",
    "docs": "docs/",
    "specs": "docs/specs/",
    "artifacts": ".claude/artifacts/",
    "state": ".claude/artifacts/workflow-state-{branch-slug}.json"
  }
}
PYEOF
      ;;
    rust)
      cat <<RSEOF
{
  "project": {
    "name": "$name",
    "language": "rust",
    "description": ""
  },
  "commands": {
    "test": "cargo test",
    "test_verbose": "cargo test -- --nocapture",
    "coverage": "cargo tarpaulin",
    "lint": "cargo clippy",
    "build": "cargo build"
  },
  "patterns": {
    "test_file": "*_test.rs|tests/*.rs",
    "source_file": "*.rs",
    "test_fail_pattern": "FAILED|failures",
    "build_error_pattern": "error\\[E|cannot find"
  },
  "is_monorepo": false,
  "packages": {},
  "workflow": {
    "min_qa_rounds": 1,
    "require_review": true,
    "auto_update_antipatterns": true,
    "git_trailers": false,
    "git_notes": false
  },
  "paths": {
    "architecture_doc": "ARCHITECTURE.md",
    "agent_context": "AGENT_CONTEXT.md",
    "antipatterns": ".claude/antipatterns.md",
    "docs": "docs/",
    "specs": "docs/specs/",
    "artifacts": ".claude/artifacts/",
    "state": ".claude/artifacts/workflow-state-{branch-slug}.json"
  }
}
RSEOF
      ;;
    *)
      cat <<OTHEREOF
{
  "project": {
    "name": "$name",
    "language": "other",
    "description": ""
  },
  "commands": {
    "test": "",
    "test_verbose": "",
    "coverage": "",
    "lint": "",
    "build": ""
  },
  "patterns": {
    "test_file": "",
    "source_file": "",
    "test_fail_pattern": "",
    "build_error_pattern": ""
  },
  "is_monorepo": false,
  "packages": {},
  "workflow": {
    "min_qa_rounds": 1,
    "require_review": true,
    "auto_update_antipatterns": true,
    "git_trailers": false,
    "git_notes": false
  },
  "paths": {
    "architecture_doc": "ARCHITECTURE.md",
    "agent_context": "AGENT_CONTEXT.md",
    "antipatterns": ".claude/antipatterns.md",
    "docs": "docs/",
    "specs": "docs/specs/",
    "artifacts": ".claude/artifacts/",
    "state": ".claude/artifacts/workflow-state-{branch-slug}.json"
  }
}
OTHEREOF
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Install hooks to stable project-local path
# ---------------------------------------------------------------------------

install_hooks() {
  local hook_dest="$REPO_ROOT/.claude/hooks"
  mkdir -p "$hook_dest"

  cp "$SCRIPT_DIR/hooks/workflow-gate.sh" "$hook_dest/workflow-gate.sh"
  cp "$SCRIPT_DIR/hooks/workflow-advance.sh" "$hook_dest/workflow-advance.sh"
  cp "$SCRIPT_DIR/hooks/statusline.sh" "$hook_dest/statusline.sh"
  cp "$SCRIPT_DIR/hooks/audit-trail.sh" "$hook_dest/audit-trail.sh"
  chmod +x "$hook_dest/workflow-gate.sh" "$hook_dest/workflow-advance.sh" "$hook_dest/statusline.sh" "$hook_dest/audit-trail.sh"
  ok "Installed hooks to .claude/hooks/"
}

# ---------------------------------------------------------------------------
# Register hooks in .claude/settings.json
# ---------------------------------------------------------------------------

register_hooks() {
  local settings="$REPO_ROOT/.claude/settings.json"
  local hook_path=".claude/hooks/workflow-gate.sh"
  local advance_path=".claude/hooks/workflow-advance.sh"

  mkdir -p "$(dirname "$settings")"

  local statusline_path=".claude/hooks/statusline.sh"
  local audit_path=".claude/hooks/audit-trail.sh"

  if [ ! -f "$settings" ]; then
    cat > "$settings" <<HEOF
{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|CreateFile|Bash",
        "command": "$hook_path",
        "timeout_ms": 5000
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|CreateFile|Bash",
        "command": "$audit_path",
        "timeout_ms": 1000
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash($advance_path *)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$statusline_path"
  }
}
HEOF
    ok "Created $settings with hooks"
    return
  fi

  # Check if hook already registered
  if grep -q "workflow-gate" "$settings" 2>/dev/null; then
    skip "Hook already registered in settings.json"
    return
  fi

  # Append hook to existing settings using jq
  if command -v jq >/dev/null 2>&1; then
    local tmp="$settings.$$"
    jq --arg cmd "$hook_path" --arg adv "$advance_path" --arg sl "$statusline_path" --arg audit "$audit_path" '
      .hooks.PreToolUse = (.hooks.PreToolUse // []) + [{
        matcher: "Edit|Write|MultiEdit|NotebookEdit|CreateFile|Bash",
        command: $cmd,
        timeout_ms: 5000
      }]
      | .hooks.PostToolUse = (.hooks.PostToolUse // []) + [{
        matcher: "Edit|Write|MultiEdit|CreateFile|Bash",
        command: $audit,
        timeout_ms: 1000
      }]
      | .permissions.allow = (.permissions.allow // []) + ["Bash(\($adv) *)"]
      | .statusLine = { type: "command", command: $sl }
    ' "$settings" > "$tmp" && mv "$tmp" "$settings"
    ok "Registered hooks in existing settings.json"
  else
    warn "Cannot auto-register hooks (jq not found). Add manually to $settings"
  fi
}

# ---------------------------------------------------------------------------
# Create file if it doesn't exist
# ---------------------------------------------------------------------------

create_if_missing() {
  local dest="$1"
  local src="$2"
  local desc="$3"

  mkdir -p "$(dirname "$dest")"
  if [ -f "$dest" ]; then
    skip "$desc"
  else
    cp "$src" "$dest"
    ok "$desc"
  fi
}

# ---------------------------------------------------------------------------
# Detect existing project state for the skill agent
# ---------------------------------------------------------------------------

detect_file_state() {
  local file="$1"
  if [ ! -f "$file" ]; then
    echo "missing"
  elif grep -qiE '{PROJECT_NAME}|{PLACEHOLDER}|{Pattern [Nn]ame}|{what it does}|{2-3 sentences}' "$file" 2>/dev/null; then
    echo "template"
  else
    echo "existing"
  fi
}

# ---------------------------------------------------------------------------
# Discover test patterns beyond defaults
# ---------------------------------------------------------------------------

discover_test_patterns() {
  local config="$1"
  command -v jq >/dev/null 2>&1 || return 0

  local extra=""

  # Check for test directories (maxdepth 5 for monorepos, bail after 100 files)
  for dir in __tests__ tests test e2e spec; do
    if find "$REPO_ROOT" -maxdepth 5 -type d -name "$dir" 2>/dev/null | head -1 | grep -q .; then
      info "  Test directory found: $dir/"
      case "$dir" in
        __tests__) extra="${extra:+$extra|}__tests__/**/*" ;;
        tests)     extra="${extra:+$extra|}tests/**/*" ;;
        test)      extra="${extra:+$extra|}test/**/*" ;;
        e2e)       extra="${extra:+$extra|}e2e/**/*" ;;
        spec)      extra="${extra:+$extra|}spec/**/*" ;;
      esac
    fi
  done

  # Check for non-standard test suffixes
  for suffix in integration e2e acceptance; do
    if find "$REPO_ROOT" -maxdepth 5 -name "*.${suffix}.*" -type f 2>/dev/null | head -1 | grep -q .; then
      info "  Test suffix found: .${suffix}.*"
      extra="${extra:+$extra|}*.${suffix}.*"
    fi
  done

  # Merge discovered patterns into config
  if [ -n "$extra" ]; then
    local current merged
    current="$(jq -r '.patterns.test_file' "$config")"
    if [ -n "$current" ] && [ "$current" != "null" ]; then
      merged="${current}|${extra}"
    else
      merged="${extra}"
    fi
    jq --arg p "$merged" '.patterns.test_file = $p' "$config" > "$config.$$" \
      && mv "$config.$$" "$config"
    ok "Merged discovered test patterns into config"
  fi
}

# ---------------------------------------------------------------------------
# Detect monorepo type
# ---------------------------------------------------------------------------

detect_monorepo_type() {
  if [ -f "$REPO_ROOT/pnpm-workspace.yaml" ]; then echo "pnpm"
  elif [ -f "$REPO_ROOT/lerna.json" ]; then echo "lerna"
  elif [ -f "$REPO_ROOT/nx.json" ]; then echo "nx"
  elif [ -f "$REPO_ROOT/turbo.json" ]; then echo "turbo"
  elif [ -f "$REPO_ROOT/rush.json" ]; then echo "rush"
  elif [ -f "$REPO_ROOT/go.work" ]; then echo "go-workspace"
  elif [ -f "$REPO_ROOT/Cargo.toml" ] && grep -q '^\[workspace\]' "$REPO_ROOT/Cargo.toml" 2>/dev/null; then echo "cargo-workspace"
  elif [ -f "$REPO_ROOT/package.json" ] && jq -e '.workspaces' "$REPO_ROOT/package.json" >/dev/null 2>&1; then echo "npm-workspaces"
  else echo "none"
  fi
}

# ---------------------------------------------------------------------------
# Detect existing tooling that might conflict or overlap
# ---------------------------------------------------------------------------

detect_existing_tools() {
  echo ""
  info "Existing tooling:"

  # Hook systems
  if [ -d "$REPO_ROOT/.husky" ]; then
    ok "Git hooks: husky"
  fi
  if grep -q '"lint-staged"' "$REPO_ROOT/package.json" 2>/dev/null; then
    ok "Git hooks: lint-staged"
  fi
  if [ -f "$REPO_ROOT/.pre-commit-config.yaml" ]; then
    ok "Git hooks: pre-commit framework"
  fi
  if [ -f "$REPO_ROOT/lefthook.yml" ]; then
    ok "Git hooks: lefthook"
  fi

  # CI (check all — projects may use multiple)
  if [ -d "$REPO_ROOT/.github/workflows" ]; then ok "CI: GitHub Actions"; fi
  if [ -f "$REPO_ROOT/.gitlab-ci.yml" ]; then ok "CI: GitLab CI"; fi
  if [ -f "$REPO_ROOT/.circleci/config.yml" ]; then ok "CI: CircleCI"; fi
  if [ -f "$REPO_ROOT/Jenkinsfile" ]; then ok "CI: Jenkins"; fi

  # Coverage
  for f in .nycrc .nycrc.json .coveragerc tarpaulin.toml; do
    if [ -f "$REPO_ROOT/$f" ]; then
      ok "Coverage config: $f"
      break
    fi
  done
  if grep -q 'coverageThreshold\|collectCoverage' "$REPO_ROOT/jest.config"* 2>/dev/null || \
     grep -q 'coverageThreshold\|collectCoverage' "$REPO_ROOT/package.json" 2>/dev/null; then
    ok "Coverage config: jest"
  fi
  if grep -q '\[tool\.coverage\]' "$REPO_ROOT/pyproject.toml" 2>/dev/null; then
    ok "Coverage config: pyproject.toml"
  fi
}

# ---------------------------------------------------------------------------
# Detect Full mode tools
# ---------------------------------------------------------------------------

detect_full_tools() {
  # Mutation testing
  if command -v go-mutesting >/dev/null 2>&1; then ok "Mutation tool: go-mutesting"; fi
  if command -v npx >/dev/null 2>&1 && npx --no stryker --version 2>/dev/null >/dev/null 2>&1; then ok "Mutation tool: Stryker"; fi
  if command -v cargo-mutants >/dev/null 2>&1; then ok "Mutation tool: cargo-mutants"; fi
  if command -v mutmut >/dev/null 2>&1; then ok "Mutation tool: mutmut"; fi

  # Alloy — check $ALLOY_JAR env var, then common install locations
  if [ -n "${ALLOY_JAR:-}" ] && [ -f "$ALLOY_JAR" ]; then
    ok "Alloy Analyzer: $ALLOY_JAR"
  elif command -v alloy >/dev/null 2>&1; then
    ok "Alloy Analyzer: alloy CLI found in PATH"
  else
    info "  Alloy: not found (set \$ALLOY_JAR or install to PATH to enable formal modeling)"
  fi

  # External model CLIs
  if command -v codex >/dev/null 2>&1; then ok "External model: codex CLI"; fi
  if command -v gemini >/dev/null 2>&1; then ok "External model: gemini CLI"; fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

echo ""
echo "Correctless — Setup"
echo "==================="
echo ""

# Check for jq — hooks require it
if ! command -v jq >/dev/null 2>&1; then
  warn "jq is not installed. The workflow hooks require jq to function."
  warn "Install: brew install jq (macOS) / apt install jq (Debian) / pacman -S jq (Arch)"
  echo ""
fi

# Detect language
DETECTED_LANG="$(detect_language)"
ok "Detected: $DETECTED_LANG project"

# Check if config already exists and if it's Full mode
CONFIG_DEST="$REPO_ROOT/.claude/workflow-config.json"
IS_FULL="false"
if [ -f "$CONFIG_DEST" ]; then
  skip "workflow-config.json (already exists)"
  if jq -e '.workflow.intensity' "$CONFIG_DEST" >/dev/null 2>&1; then
    IS_FULL="true"
    ok "Mode: Full (intensity: $(jq -r '.workflow.intensity' "$CONFIG_DEST"))"
  else
    ok "Mode: Lite"
  fi
else
  MONO_TYPE="$(detect_monorepo_type)"
  if [ "$MONO_TYPE" != "none" ]; then
    ok "Monorepo detected: $MONO_TYPE"
    info "Per-package configuration will be set up by /csetup"
  fi

  mkdir -p "$(dirname "$CONFIG_DEST")"
  detect_config "$DETECTED_LANG" > "$CONFIG_DEST"
  ok "Generated workflow-config.json (Lite mode — edit to add intensity for Full mode)"

  if [ "$MONO_TYPE" != "none" ] && command -v jq >/dev/null 2>&1 && [ -f "$CONFIG_DEST" ]; then
    jq '.is_monorepo = true' "$CONFIG_DEST" > "$CONFIG_DEST.$$" && mv "$CONFIG_DEST.$$" "$CONFIG_DEST"
  fi
fi

# Create common templates
create_if_missing "$REPO_ROOT/ARCHITECTURE.md" "$SCRIPT_DIR/templates/ARCHITECTURE.md" "ARCHITECTURE.md"
create_if_missing "$REPO_ROOT/AGENT_CONTEXT.md" "$SCRIPT_DIR/templates/AGENT_CONTEXT.md" "AGENT_CONTEXT.md"
create_if_missing "$REPO_ROOT/.claude/antipatterns.md" "$SCRIPT_DIR/templates/antipatterns.md" "antipatterns.md"

# Record file state for the skill agent (template, existing, or missing→template)
# Detect file states (used for config and summary output)
ARCH_STATE="$(detect_file_state "$REPO_ROOT/ARCHITECTURE.md")"
AGENT_STATE="$(detect_file_state "$REPO_ROOT/AGENT_CONTEXT.md")"

if command -v jq >/dev/null 2>&1 && [ -f "$CONFIG_DEST" ]; then
  jq --arg a "$ARCH_STATE" --arg c "$AGENT_STATE" \
    '.setup = { architecture_state: $a, agent_context_state: $c }' \
    "$CONFIG_DEST" > "$CONFIG_DEST.$$" && mv "$CONFIG_DEST.$$" "$CONFIG_DEST"
  if [ "$ARCH_STATE" = "existing" ]; then
    info "ARCHITECTURE.md has real content — /csetup will offer to add Correctless sections"
  fi
  if [ "$AGENT_STATE" = "existing" ]; then
    info "AGENT_CONTEXT.md has real content — /csetup will offer to add Correctless sections"
  fi
fi

# Create directory structure
mkdir -p "$REPO_ROOT/docs/specs" "$REPO_ROOT/docs/features" "$REPO_ROOT/docs/verification"
ok "Created docs/ directories"

mkdir -p "$REPO_ROOT/.claude/artifacts"
ok "Created .claude/artifacts/"

# Full mode: create additional directories and meta files
if [ "$IS_FULL" = "true" ]; then
  mkdir -p "$REPO_ROOT/docs/models" "$REPO_ROOT/docs/diagrams" "$REPO_ROOT/docs/decisions"
  ok "Created Full mode docs/ directories (models, diagrams, decisions)"

  mkdir -p "$REPO_ROOT/.claude/meta"
  create_if_missing "$REPO_ROOT/.claude/meta/workflow-effectiveness.json" "$SCRIPT_DIR/templates/workflow-effectiveness.json" "workflow-effectiveness.json"
  create_if_missing "$REPO_ROOT/.claude/meta/drift-debt.json" "$SCRIPT_DIR/templates/drift-debt.json" "drift-debt.json"
  create_if_missing "$REPO_ROOT/.claude/meta/external-review-history.json" "$SCRIPT_DIR/templates/external-review-history.json" "external-review-history.json"

  echo ""
  info "Full mode tools:"
  detect_full_tools
fi

# Discover test patterns and existing tooling
discover_test_patterns "$CONFIG_DEST"
detect_existing_tools

# Install hooks to project-local path and register in settings
install_hooks
register_hooks

# Update .gitignore
GITIGNORE="$REPO_ROOT/.gitignore"
if [ -f "$GITIGNORE" ] && grep -q '.claude/artifacts/' "$GITIGNORE" 2>/dev/null; then
  skip ".gitignore already includes .claude/artifacts/"
else
  echo "" >> "$GITIGNORE" 2>/dev/null || true
  echo "# Correctless — transient workflow state" >> "$GITIGNORE"
  echo ".claude/artifacts/" >> "$GITIGNORE"
  ok "Updated .gitignore"
fi

# Update CLAUDE.md
CLAUDEMD="$REPO_ROOT/CLAUDE.md"
if [ -f "$CLAUDEMD" ] && grep -q 'Correctless' "$CLAUDEMD" 2>/dev/null; then
  skip "CLAUDE.md already references Correctless"
else
  if [ "$IS_FULL" = "true" ]; then
    cat >> "$CLAUDEMD" <<'CMDEOF'

## Correctless

This project uses Correctless for correctness-oriented development.
Read AGENT_CONTEXT.md before starting any work.
Available commands: /csetup, /cspec, /creview, /cmodel, /creview-spec, /ctdd, /cverify, /caudit, /cupdate-arch, /cdocs, /cpostmortem, /cdevadv, /credteam, /crefactor, /cpr-review, /ccontribute, /cmaintain, /cstatus, /csummary, /cmetrics, /cdebug, /chelp, /cwtf
CMDEOF
  else
    cat >> "$CLAUDEMD" <<'CMDEOF'

## Correctless Lite

This project uses Correctless Lite for structured development.
Read AGENT_CONTEXT.md before starting any work.
Available commands: /csetup, /cspec, /creview, /ctdd, /cverify, /cdocs, /crefactor, /cpr-review, /ccontribute, /cmaintain, /cstatus, /csummary, /cmetrics, /cdebug, /chelp, /cwtf
CMDEOF
  fi
  ok "Updated CLAUDE.md"
fi

# Add Correctless Learnings section if not present
if [ -f "$CLAUDEMD" ] && ! grep -q 'Correctless Learnings' "$CLAUDEMD" 2>/dev/null; then
  cat >> "$CLAUDEMD" <<'LEARNEOF'

## Correctless Learnings
<!-- Auto-updated by Correctless workflow. Do not edit above this line. -->
LEARNEOF
  ok "Added Correctless Learnings section to CLAUDE.md"
fi

echo ""
echo "Created:"
echo "  .claude/workflow-config.json  <- review and adjust"
if [ "$ARCH_STATE" = "template" ]; then
