#!/usr/bin/env bash
# Correctless — install script
# Auto-detects project language, test runner, and tools.
# Registers hooks, creates templates, generates config.
# Supports configurable intensity levels (standard, high, critical).
# Idempotent — re-running never overwrites user-edited files.

set -euo pipefail

# Fail-fast prerequisites
if [[ "${BASH_VERSINFO[0]}" -lt 4 ]]; then
  echo "ERROR: Correctless requires Bash 4+. You have Bash ${BASH_VERSION}." >&2
  echo "  macOS: brew install bash" >&2
  echo "  Ubuntu: sudo apt install bash" >&2
  exit 1
fi

if ! git rev-parse --show-toplevel >/dev/null 2>&1; then
  echo "ERROR: Not in a git repository. Run setup from within a git project." >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"

info()  { echo "  $*"; }
ok()    { echo "  ✓ $*"; }
skip()  { echo "  - $* (already exists)"; }
warn()  { echo "  ! $*"; }

# ---------------------------------------------------------------------------
# Detect project language
# ---------------------------------------------------------------------------

detect_language() {
  if [ -f "$REPO_ROOT/go.mod" ]; then
    echo "go"
  elif [ -f "$REPO_ROOT/package.json" ]; then
    echo "typescript"
  elif [ -f "$REPO_ROOT/Cargo.toml" ]; then
    echo "rust"
  elif [ -f "$REPO_ROOT/pyproject.toml" ] || [ -f "$REPO_ROOT/requirements.txt" ] || [ -f "$REPO_ROOT/setup.py" ]; then
    echo "python"
  elif [ -f "$REPO_ROOT/pom.xml" ] || [ -f "$REPO_ROOT/build.gradle" ]; then
    echo "java"
  else
    echo "other"
  fi
}

# ---------------------------------------------------------------------------
# Detect commands and patterns per language (no paths section)
# ---------------------------------------------------------------------------

detect_config() {
  local lang="$1"
  local name
  name="$(basename "$REPO_ROOT")"

  case "$lang" in
    go)
      cat <<GOEOF
{
  "project": {
    "name": "$name",
    "language": "go",
    "description": ""
  },
  "commands": {
    "test": "go test ./...",
    "test_verbose": "go test -v ./...",
    "coverage": "go test -coverprofile=coverage.out ./...",
    "lint": "go vet ./...",
    "build": "go build ./..."
  },
  "patterns": {
    "test_file": "*_test.go",
    "source_file": "*.go",
    "test_fail_pattern": "FAIL",
    "build_error_pattern": "cannot|undefined|syntax error"
  },
  "is_monorepo": false,
  "packages": {},
  "workflow": {
    "min_qa_rounds": 1,
    "require_review": true,
    "auto_update_antipatterns": true,
    "git_trailers": false,
    "git_notes": false
  }
}
GOEOF
      ;;
    typescript)
      # Detect package manager and test runner
      local test_cmd="npm test"
      local test_verbose="npm test -- --verbose"
      local coverage="npm test -- --coverage"
      local lint="npm run lint"
      local build="npm run build"

      if [ -f "$REPO_ROOT/pnpm-lock.yaml" ]; then
        test_cmd="pnpm test"
        test_verbose="pnpm test -- --verbose"
        coverage="pnpm test -- --coverage"
        lint="pnpm run lint"
        build="pnpm run build"
      elif [ -f "$REPO_ROOT/yarn.lock" ]; then
        test_cmd="yarn test"
        test_verbose="yarn test --verbose"
        coverage="yarn test --coverage"
        lint="yarn lint"
        build="yarn build"
      fi

      cat <<TSEOF
{
  "project": {
    "name": "$name",
    "language": "typescript",
    "description": ""
  },
  "commands": {
    "test": "$test_cmd",
    "test_verbose": "$test_verbose",
    "coverage": "$coverage",
    "lint": "$lint",
    "build": "$build"
  },
  "patterns": {
    "test_file": "*.test.ts|*.test.tsx|*.spec.ts|*.spec.tsx",
    "source_file": "*.ts|*.tsx",
    "test_fail_pattern": "FAIL|failing",
    "build_error_pattern": "error TS|Cannot find|SyntaxError"
  },
  "is_monorepo": false,
  "packages": {},
  "workflow": {
    "min_qa_rounds": 1,
    "require_review": true,
    "auto_update_antipatterns": true,
    "git_trailers": false,
    "git_notes": false
  }
}
TSEOF
      ;;
    python)
      local test_cmd="pytest"
      local coverage="pytest --cov"
      local lint="ruff check ."
      if [ -f "$REPO_ROOT/.flake8" ] || grep -q 'flake8' "$REPO_ROOT/pyproject.toml" 2>/dev/null; then lint="flake8 ."; fi

      cat <<PYEOF
{
  "project": {
    "name": "$name",
    "language": "python",
    "description": ""
  },
  "commands": {
    "test": "$test_cmd",
    "test_verbose": "pytest -v",
    "coverage": "$coverage",
    "lint": "$lint",
    "build": ""
  },
  "patterns": {
    "test_file": "test_*.py|*_test.py",
    "source_file": "*.py",
    "test_fail_pattern": "FAILED|ERROR",
    "build_error_pattern": "SyntaxError|ImportError"
  },
  "is_monorepo": false,
  "packages": {},
  "workflow": {
    "min_qa_rounds": 1,
    "require_review": true,
    "auto_update_antipatterns": true,
    "git_trailers": false,
    "git_notes": false
  }
}
PYEOF
      ;;
    rust)
      cat <<RSEOF
{
  "project": {
    "name": "$name",
    "language": "rust",
    "description": ""
  },
  "commands": {
    "test": "cargo test",
    "test_verbose": "cargo test -- --nocapture",
    "coverage": "cargo tarpaulin",
    "lint": "cargo clippy",
    "build": "cargo build"
  },
  "patterns": {
    "test_file": "*_test.rs|tests/*.rs",
    "source_file": "*.rs",
    "test_fail_pattern": "FAILED|failures",
    "build_error_pattern": "error\\\\[E|cannot find"
  },
  "is_monorepo": false,
  "packages": {},
  "workflow": {
    "min_qa_rounds": 1,
    "require_review": true,
    "auto_update_antipatterns": true,
    "git_trailers": false,
    "git_notes": false
  }
}
RSEOF
      ;;
    *)
      cat <<OTHEREOF
{
  "project": {
    "name": "$name",
    "language": "other",
    "description": ""
  },
  "commands": {
    "test": "",
    "test_verbose": "",
    "coverage": "",
    "lint": "",
    "build": ""
  },
  "patterns": {
    "test_file": "",
    "source_file": "",
    "test_fail_pattern": "",
    "build_error_pattern": ""
  },
  "is_monorepo": false,
  "packages": {},
  "workflow": {
    "min_qa_rounds": 1,
    "require_review": true,
    "auto_update_antipatterns": true,
    "git_trailers": false,
    "git_notes": false
  }
}
OTHEREOF
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Install hooks to .correctless/hooks/
# ---------------------------------------------------------------------------

install_hooks() {
  local hook_dest="$REPO_ROOT/.correctless/hooks"
  mkdir -p "$hook_dest"

  # Auto-discover hooks via glob — adding a new .sh file to hooks/ requires no code change
  for hook in "$SCRIPT_DIR"/hooks/*.sh; do
    [ -f "$hook" ] || continue
    local basename_hook
    basename_hook="$(basename "$hook")"
    # QA-R1-001: Always copy hooks — they are generated code, not user-edited.
    # The [ ! -f ] guard prevented updates, causing stale hook drift.
    cp "$hook" "$hook_dest/$basename_hook"
    chmod +x "$hook_dest/$basename_hook" 2>/dev/null || true
  done
  ok "Installed hooks to .correctless/hooks/"

  # Install phase-transition scripts (sourced by hooks and invoked by skills)
  if [ -d "$SCRIPT_DIR/scripts" ]; then
    local script_dest="$REPO_ROOT/scripts"
    mkdir -p "$script_dest"
    # QA-R2-003: Always copy scripts (same as hooks — generated code, not user-edited)
    for script in lib.sh antipattern-scan.sh; do
      if [ -f "$SCRIPT_DIR/scripts/$script" ]; then
        cp "$SCRIPT_DIR/scripts/$script" "$script_dest/$script"
      fi
    done
    chmod +x "$script_dest/antipattern-scan.sh" 2>/dev/null || true
  fi
}

# ---------------------------------------------------------------------------
# Register hooks in .claude/settings.json (paths point to .correctless/hooks/)
# ---------------------------------------------------------------------------

register_hooks() {
  local settings="$REPO_ROOT/.claude/settings.json"
  local advance_path=".correctless/hooks/workflow-advance.sh"
  local statusline_path=".correctless/hooks/statusline.sh"

  mkdir -p "$(dirname "$settings")"

  if ! command -v jq >/dev/null 2>&1; then
    warn "Cannot auto-register hooks (jq not found). Add manually to $settings"
    return
  fi

  # ============================================
  # Auto-discover hooks via metadata headers (INV-004)
  # Reads HOOK_TYPE and HOOK_MATCHER from each hook's first 10 lines.
  # Files without HOOK_TYPE are skipped (INV-006).
  # Timeout convention: PreToolUse=5000ms, PostToolUse=1000ms.
  # ============================================

  # Build arrays of hook entries from metadata headers
  local -a pre_hooks=()
  local -a post_hooks=()

  for hook in "$SCRIPT_DIR"/hooks/*.sh; do
    [ -f "$hook" ] || continue
    local basename_hook
    basename_hook="$(basename "$hook")"
    local hook_cmd=".correctless/hooks/$basename_hook"

    # Read metadata from first 10 lines
    local first10
    first10="$(head -10 "$hook")"

    local hook_type hook_matcher
    hook_type="$(echo "$first10" | sed -n 's/^# HOOK_TYPE:[[:space:]]*\([^ ]*\).*/\1/p' | head -1)"
    hook_matcher="$(echo "$first10" | sed -n '/^# HOOK_MATCHER:/{s/^# HOOK_MATCHER:[[:space:]]*//;s/[[:space:]]*$//;p;}' | head -1 | tr -d ' ')"

    # Skip files without HOOK_TYPE header (INV-006)
    [ -n "$hook_type" ] || continue
    [ -n "$hook_matcher" ] || continue

    case "$hook_type" in
      PreToolUse)
        pre_hooks+=("$hook_cmd|$hook_matcher")
        ;;
      PostToolUse)
        post_hooks+=("$hook_cmd|$hook_matcher")
        ;;
    esac
  done

  if [ ! -f "$settings" ]; then
    # ============================================
    # Fresh install — generate settings.json from discovered hooks
    # ============================================

    # Build PreToolUse JSON array
    local pre_json="[]"
    for entry in "${pre_hooks[@]}"; do
      local cmd="${entry%%|*}"
      local matcher="${entry#*|}"
      pre_json="$(echo "$pre_json" | jq --arg cmd "$cmd" --arg matcher "$matcher" \
        '. + [{ matcher: $matcher, hooks: [{ type: "command", command: $cmd, timeout_ms: 5000 }] }]')"
    done

    # Build PostToolUse JSON array
    local post_json="[]"
    for entry in "${post_hooks[@]}"; do
      local cmd="${entry%%|*}"
      local matcher="${entry#*|}"
      post_json="$(echo "$post_json" | jq --arg cmd "$cmd" --arg matcher "$matcher" \
        '. + [{ matcher: $matcher, hooks: [{ type: "command", command: $cmd, timeout_ms: 1000 }] }]')"
    done

    # Assemble the full settings.json
    jq -n --argjson pre "$pre_json" --argjson post "$post_json" \
      --arg sl "$statusline_path" --arg adv "$advance_path" \
      '{
        hooks: { PreToolUse: $pre, PostToolUse: $post },
        statusLine: { command: $sl },
        permissions: { allow: [ "Bash(\($adv) *)" ] }
      }' > "$settings"

    ok "Created $settings with hooks"
    return
  fi

  # ============================================
  # Existing settings.json — check and append missing hooks
  # ============================================

  # Validate settings.json is valid JSON before processing (F1: prevents set -e crash)
  if [ ! -s "$settings" ] || ! jq empty "$settings" 2>/dev/null; then
    warn "settings.json contains invalid JSON — regenerating hook configuration"
    rm -f "$settings"
    # Fall through to fresh-install path by re-calling ourselves
    register_hooks
    return
  fi

  local needs_update="false"

  # Check if all discovered hooks are registered (F2: use jq instead of grep for structural check)
  local settings_json
  settings_json="$(cat "$settings")"
  for entry in "${pre_hooks[@]}"; do
    local cmd="${entry%%|*}"
    if ! echo "$settings_json" | jq -e --arg cmd "$cmd" '(.hooks.PreToolUse // [] | any(.hooks[]?.command == $cmd))' >/dev/null 2>&1; then
      needs_update="true"
      break
    fi
  done
  if [ "$needs_update" = "false" ]; then
    for entry in "${post_hooks[@]}"; do
      local cmd="${entry%%|*}"
      if ! echo "$settings_json" | jq -e --arg cmd "$cmd" '(.hooks.PostToolUse // [] | any(.hooks[]?.command == $cmd))' >/dev/null 2>&1; then
        needs_update="true"
        break
      fi
    done
  fi

  # Check for matcher drift — matchers are authoritative from HOOK_MATCHER headers (INV-004)
  if [ "$needs_update" = "false" ]; then
    for entry in "${pre_hooks[@]}"; do
      local cmd="${entry%%|*}" matcher="${entry#*|}"
      local current
      current="$(jq -r --arg cmd "$cmd" '(.hooks.PreToolUse // [] | .[] | select(.hooks[]?.command == $cmd) | .matcher) // ""' "$settings" 2>/dev/null || echo "")"
      if [ -n "$current" ] && [ "$current" != "$matcher" ]; then
        needs_update="true"
        break
      fi
    done
  fi
  if [ "$needs_update" = "false" ]; then
    for entry in "${post_hooks[@]}"; do
      local cmd="${entry%%|*}" matcher="${entry#*|}"
      local current
      current="$(jq -r --arg cmd "$cmd" '(.hooks.PostToolUse // [] | .[] | select(.hooks[]?.command == $cmd) | .matcher) // ""' "$settings" 2>/dev/null || echo "")"
      if [ -n "$current" ] && [ "$current" != "$matcher" ]; then
        needs_update="true"
        break
      fi
    done
  fi

  # Also check hardcoded entries (INV-007)
  if ! grep -q "workflow-advance" "$settings" 2>/dev/null; then
    needs_update="true"
  fi
  if ! grep -q "statusLine" "$settings" 2>/dev/null; then
    needs_update="true"
  fi

  if [ "$needs_update" = "false" ]; then
    skip "Hooks already registered in settings.json"
    return
  fi

  # Append missing hook entries
  local tmp="$settings.$$"
  local result
  result="$(cat "$settings")"

  # Add or update PreToolUse hooks — matchers are authoritative from HOOK_MATCHER headers
  for entry in "${pre_hooks[@]}"; do
    local cmd="${entry%%|*}"
    local matcher="${entry#*|}"
    result="$(echo "$result" | jq --arg cmd "$cmd" --arg matcher "$matcher" '
      .hooks.PreToolUse = (
        if (.hooks.PreToolUse // [] | any(.hooks[]?.command == $cmd)) then
          [.hooks.PreToolUse[] | if any(.hooks[]?.command; . == $cmd) then .matcher = $matcher else . end]
        else
          (.hooks.PreToolUse // []) + [{
            matcher: $matcher,
            hooks: [{type: "command", command: $cmd, timeout_ms: 5000}]
          }]
        end
      )
    ')"
  done

  # Add or update PostToolUse hooks — matchers are authoritative from HOOK_MATCHER headers
  for entry in "${post_hooks[@]}"; do
    local cmd="${entry%%|*}"
    local matcher="${entry#*|}"
    result="$(echo "$result" | jq --arg cmd "$cmd" --arg matcher "$matcher" '
      .hooks.PostToolUse = (
        if (.hooks.PostToolUse // [] | any(.hooks[]?.command == $cmd)) then
          [.hooks.PostToolUse[] | if any(.hooks[]?.command; . == $cmd) then .matcher = $matcher else . end]
        else
          (.hooks.PostToolUse // []) + [{
            matcher: $matcher,
            hooks: [{type: "command", command: $cmd, timeout_ms: 1000}]
          }]
        end
      )
    ')"
  done

  # Ensure hardcoded entries (INV-007)
  result="$(echo "$result" | jq --arg sl "$statusline_path" --arg adv "$advance_path" '
    .statusLine.command = $sl
    | .permissions.allow = (
        if (.permissions.allow // [] | any(. == "Bash(\($adv) *)")) then
          .permissions.allow
        else
          (.permissions.allow // []) + ["Bash(\($adv) *)"]
        end
      )
  ')"

  if echo "$result" > "$tmp" 2>/dev/null && mv "$tmp" "$settings"; then
    ok "Registered hooks in existing settings.json"
  else
    rm -f "$tmp"
    warn "settings.json may contain invalid JSON — hooks not auto-registered. Add manually to $settings"
  fi
}

# ---------------------------------------------------------------------------
# Create file if it doesn't exist
# ---------------------------------------------------------------------------

create_if_missing() {
  local dest="$1"
  local src="$2"
  local desc="$3"

  mkdir -p "$(dirname "$dest")"
  if [ -f "$dest" ]; then
    skip "$desc"
  else
    cp "$src" "$dest"
    ok "$desc"
  fi
}

# ---------------------------------------------------------------------------
# Detect existing project state for the skill agent
# ---------------------------------------------------------------------------

detect_file_state() {
  local file="$1"
  if [ ! -f "$file" ]; then
    echo "missing"
  elif grep -qiE '{PROJECT_NAME}|{PLACEHOLDER}|{Pattern [Nn]ame}|{what it does}|{2-3 sentences}' "$file" 2>/dev/null; then
    echo "template"
  else
    echo "existing"
  fi
}

# ---------------------------------------------------------------------------
# Check if a file has Correctless markers (template placeholders or generated headers)
# ---------------------------------------------------------------------------

has_correctless_markers() {
  local file="$1"
  [ -f "$file" ] || return 1
  [ "$(detect_file_state "$file")" = "template" ] && return 0
  grep -qE '^# Architecture —|^# Agent Context —' "$file" 2>/dev/null && return 0
  return 1
}

# ---------------------------------------------------------------------------
# Discover test patterns beyond defaults
# ---------------------------------------------------------------------------

discover_test_patterns() {
  local config="$1"
  command -v jq >/dev/null 2>&1 || return 0

  local extra=""

  # Check for test directories (maxdepth 5 for monorepos, bail after 100 files)
  for dir in __tests__ tests test e2e spec; do
    if find "$REPO_ROOT" -maxdepth 5 -type d -name "$dir" 2>/dev/null | head -1 | grep -q .; then
      info "  Test directory found: $dir/"
      case "$dir" in
        __tests__) extra="${extra:+$extra|}__tests__/**/*" ;;
        tests)     extra="${extra:+$extra|}tests/**/*" ;;
        test)      extra="${extra:+$extra|}test/**/*" ;;
        e2e)       extra="${extra:+$extra|}e2e/**/*" ;;
        spec)      extra="${extra:+$extra|}spec/**/*" ;;
      esac
    fi
  done

  # Check for non-standard test suffixes
  for suffix in integration e2e acceptance; do
    if find "$REPO_ROOT" -maxdepth 5 -name "*.${suffix}.*" -type f 2>/dev/null | head -1 | grep -q .; then
      info "  Test suffix found: .${suffix}.*"
      extra="${extra:+$extra|}*.${suffix}.*"
    fi
  done

  # Merge discovered patterns into config
  if [ -n "$extra" ]; then
    local current merged
    current="$(jq -r '.patterns.test_file' "$config")"
    if [ -n "$current" ] && [ "$current" != "null" ]; then
      merged="${current}|${extra}"
    else
      merged="${extra}"
    fi
    jq --arg p "$merged" '.patterns.test_file = $p' "$config" > "$config.$$" \
      && mv "$config.$$" "$config"
    ok "Merged discovered test patterns into config"
  fi
}

# ---------------------------------------------------------------------------
# Detect monorepo type
# ---------------------------------------------------------------------------

detect_monorepo_type() {
  if [ -f "$REPO_ROOT/pnpm-workspace.yaml" ]; then echo "pnpm"
  elif [ -f "$REPO_ROOT/lerna.json" ]; then echo "lerna"
  elif [ -f "$REPO_ROOT/nx.json" ]; then echo "nx"
  elif [ -f "$REPO_ROOT/turbo.json" ]; then echo "turbo"
  elif [ -f "$REPO_ROOT/rush.json" ]; then echo "rush"
  elif [ -f "$REPO_ROOT/go.work" ]; then echo "go-workspace"
  elif [ -f "$REPO_ROOT/Cargo.toml" ] && grep -q '^\[workspace\]' "$REPO_ROOT/Cargo.toml" 2>/dev/null; then echo "cargo-workspace"
  elif [ -f "$REPO_ROOT/package.json" ] && jq -e '.workspaces' "$REPO_ROOT/package.json" >/dev/null 2>&1; then echo "npm-workspaces"
  else echo "none"
  fi
}

# ---------------------------------------------------------------------------
# Detect existing tooling that might conflict or overlap
# ---------------------------------------------------------------------------

detect_existing_tools() {
  echo ""
  info "Existing tooling:"

  # Hook systems
  if [ -d "$REPO_ROOT/.husky" ]; then
    ok "Git hooks: husky"
  fi
  if grep -q '"lint-staged"' "$REPO_ROOT/package.json" 2>/dev/null; then
    ok "Git hooks: lint-staged"
  fi
  if [ -f "$REPO_ROOT/.pre-commit-config.yaml" ]; then
    ok "Git hooks: pre-commit framework"
  fi
  if [ -f "$REPO_ROOT/lefthook.yml" ]; then
    ok "Git hooks: lefthook"
  fi

  # CI (check all — projects may use multiple)
  if [ -d "$REPO_ROOT/.github/workflows" ]; then ok "CI: GitHub Actions"; fi
  if [ -f "$REPO_ROOT/.gitlab-ci.yml" ]; then ok "CI: GitLab CI"; fi
  if [ -f "$REPO_ROOT/.circleci/config.yml" ]; then ok "CI: CircleCI"; fi
  if [ -f "$REPO_ROOT/Jenkinsfile" ]; then ok "CI: Jenkins"; fi

  # Coverage
  for f in .nycrc .nycrc.json .coveragerc tarpaulin.toml; do
    if [ -f "$REPO_ROOT/$f" ]; then
      ok "Coverage config: $f"
      break
    fi
  done
  if grep -q 'coverageThreshold\|collectCoverage' "$REPO_ROOT/jest.config"* 2>/dev/null || \
     grep -q 'coverageThreshold\|collectCoverage' "$REPO_ROOT/package.json" 2>/dev/null; then
    ok "Coverage config: jest"
  fi
  if grep -q '\[tool\.coverage\]' "$REPO_ROOT/pyproject.toml" 2>/dev/null; then
    ok "Coverage config: pyproject.toml"
  fi
}

# ---------------------------------------------------------------------------
# Detect high-intensity tools
# ---------------------------------------------------------------------------

detect_intensity_tools() {
  # Mutation testing
  if command -v go-mutesting >/dev/null 2>&1; then ok "Mutation tool: go-mutesting"; fi
  if command -v npx >/dev/null 2>&1 && npx --no stryker --version 2>/dev/null >/dev/null 2>&1; then ok "Mutation tool: Stryker"; fi
  if command -v cargo-mutants >/dev/null 2>&1; then ok "Mutation tool: cargo-mutants"; fi
  if command -v mutmut >/dev/null 2>&1; then ok "Mutation tool: mutmut"; fi

  # Alloy — check $ALLOY_JAR env var, then common install locations
  if [ -n "${ALLOY_JAR:-}" ] && [ -f "$ALLOY_JAR" ]; then
    ok "Alloy Analyzer: $ALLOY_JAR"
  elif command -v alloy >/dev/null 2>&1; then
    ok "Alloy Analyzer: alloy CLI found in PATH"
  else
    info "  Alloy: not found (set \$ALLOY_JAR or install to PATH to enable formal modeling)"
  fi

  # External model CLIs
  if command -v codex >/dev/null 2>&1; then ok "External model: codex CLI"; fi
  if command -v gemini >/dev/null 2>&1; then ok "External model: gemini CLI"; fi
}

# ---------------------------------------------------------------------------
# Detect version file for /crelease (R-004, R-013)
# ---------------------------------------------------------------------------

detect_version_file() {
  local config="$1"
  command -v jq >/dev/null 2>&1 || return 0

  local version_file=""
  local version_pattern=""

  # Check package.json
  if [ -f "$REPO_ROOT/package.json" ] && jq -e '.version' "$REPO_ROOT/package.json" >/dev/null 2>&1; then
    version_file="package.json"
    version_pattern=".version"
  # Check Cargo.toml — section-aware: version must be under [package], not [workspace]
  # QA-R1-009: Use [[:space:]] instead of \s for POSIX portability (AP-001)
  elif [ -f "$REPO_ROOT/Cargo.toml" ] && sed -n '/^\[package\]/,/^\[/p' "$REPO_ROOT/Cargo.toml" 2>/dev/null | grep -q '^version[[:space:]]*='; then
    version_file="Cargo.toml"
    version_pattern='version[[:space:]]*=[[:space:]]*"[^"]*"'
  # Check pyproject.toml — section-aware: version must be under [project]
  elif [ -f "$REPO_ROOT/pyproject.toml" ] && sed -n '/^\[project\]/,/^\[/p' "$REPO_ROOT/pyproject.toml" 2>/dev/null | grep -q '^version[[:space:]]*='; then
    version_file="pyproject.toml"
    version_pattern='version[[:space:]]*=[[:space:]]*"[^"]*"'
  # Check setup.cfg
  elif [ -f "$REPO_ROOT/setup.cfg" ] && grep -q '^version[[:space:]]*=' "$REPO_ROOT/setup.cfg" 2>/dev/null; then
    version_file="setup.cfg"
    version_pattern='version[[:space:]]*=[[:space:]]*[0-9]'
  # Check Go version constants — capture find result once to avoid double traversal
  elif go_file="$(find "$REPO_ROOT" -maxdepth 4 -name '*.go' -exec grep -l 'const Version[[:space:]]*=\|var Version[[:space:]]*=' {} + 2>/dev/null | head -1)" && [ -n "$go_file" ]; then
    # Store relative path from repo root
    version_file="${go_file#"$REPO_ROOT/"}"
    version_pattern='(const|var) Version[[:space:]]*=[[:space:]]*"[^"]*"'
  # Check CHANGELOG.md heading as fallback
  elif [ -f "$REPO_ROOT/CHANGELOG.md" ] && grep -q '## \[[0-9]' "$REPO_ROOT/CHANGELOG.md" 2>/dev/null; then
    version_file="CHANGELOG.md"
    version_pattern='## \[[0-9]+\.[0-9]+\.[0-9]+\]'
  fi

  # Skip if config is unparsable — don't attempt to sed-fix it (overly broad regex risks corruption)
  if ! jq '.' "$config" >/dev/null 2>&1; then
    warn "workflow-config.json is not valid JSON — skipping version file detection"
    return 0
  fi

  if [ -n "$version_file" ]; then
    jq --arg vf "$version_file" --arg vp "$version_pattern" \
      '.release = { version_file: $vf, version_pattern: $vp }' \
      "$config" > "$config.$$" && mv "$config.$$" "$config"
    ok "Detected version file: $version_file"
  else
    jq '.release = { version_file: null, version_pattern: null }' \
      "$config" > "$config.$$" && mv "$config.$$" "$config"
    info "No version file detected — /crelease will ask on first run"
  fi
}

# ---------------------------------------------------------------------------
# Migration: move old artifacts to .correctless/
# Old paths are constructed via variables to avoid grep false-positives
# when verifying no old-path references remain in distributions (R-015).
# ---------------------------------------------------------------------------

migrate_old_artifacts() {
  local migrated=false
  # Old path base — built from parts to avoid grep matching literal old paths
  local _c=".claude"
  local _d="docs"
  local _sk="skills/workflow"

  # Detect and clean up old Lite/Full distribution directories (R-017)
  local _lite_dir="$REPO_ROOT/${_c}/${_sk}/correctless-lite"
  local _full_dir="$REPO_ROOT/${_c}/${_sk}/correctless-full"
  if [ -d "$_lite_dir" ] || [ -d "$_full_dir" ]; then
    warn "Detected old Lite/Full directories. Migrating to unified plugin."
    if [ -d "$_lite_dir" ]; then
      rm -rf "$_lite_dir"
      ok "Removed old correctless-lite/ directory"
    fi
    if [ -d "$_full_dir" ]; then
      rm -rf "$_full_dir"
      ok "Removed old correctless-full/ directory"
    fi
    migrated=true
  fi

  # Migrate workflow-config.json
  if [ -f "$REPO_ROOT/${_c}/workflow-config.json" ] && [ ! -f "$REPO_ROOT/.correctless/config/workflow-config.json" ]; then
    mkdir -p "$REPO_ROOT/.correctless/config"
    mv "$REPO_ROOT/${_c}/workflow-config.json" "$REPO_ROOT/.correctless/config/workflow-config.json"
    # Strip paths section from migrated config (R-014)
    if command -v jq >/dev/null 2>&1; then
      jq 'del(.paths)' "$REPO_ROOT/.correctless/config/workflow-config.json" > "$REPO_ROOT/.correctless/config/workflow-config.json.$$" \
        && mv "$REPO_ROOT/.correctless/config/workflow-config.json.$$" "$REPO_ROOT/.correctless/config/workflow-config.json"
    fi
    ok "Migrated workflow-config.json to .correctless/config/"
    migrated=true
  fi

  # Helper: migrate all files from one directory to another
  migrate_dir() {
    local src="$1" dest="$2" label="$3"
    [ -d "$src" ] || return 0
    mkdir -p "$dest"
    local moved=false
    for f in "$src"/*; do
      [ -e "$f" ] || continue
      local bname
      bname="$(basename "$f")"
      if [ -d "$f" ] && [ -d "$dest/$bname" ]; then
        # Recurse into existing subdirectory
        for sub in "$f"/*; do
          [ -e "$sub" ] || continue
          local subname
          subname="$(basename "$sub")"
          [ -e "$dest/$bname/$subname" ] || { mv "$sub" "$dest/$bname/$subname"; moved=true; }
        done
      elif [ ! -e "$dest/$bname" ]; then
        mv "$f" "$dest/$bname"
        moved=true
      fi
    done
    [ "$moved" = "true" ] && ok "Migrated $label to $dest"
    [ "$moved" = "true" ] && migrated=true
  }

  migrate_dir "$REPO_ROOT/${_c}/artifacts" "$REPO_ROOT/.correctless/artifacts" "artifacts"

  # Migrate antipatterns.md
  if [ -f "$REPO_ROOT/${_c}/antipatterns.md" ] && [ ! -f "$REPO_ROOT/.correctless/antipatterns.md" ]; then
    mv "$REPO_ROOT/${_c}/antipatterns.md" "$REPO_ROOT/.correctless/antipatterns.md"
    ok "Migrated antipatterns.md to .correctless/"
    migrated=true
  fi

  migrate_dir "$REPO_ROOT/${_c}/meta" "$REPO_ROOT/.correctless/meta" "meta/"
  migrate_dir "$REPO_ROOT/${_d}/specs" "$REPO_ROOT/.correctless/specs" "specs"
  migrate_dir "$REPO_ROOT/${_d}/verification" "$REPO_ROOT/.correctless/verification" "verification"
  migrate_dir "$REPO_ROOT/${_d}/decisions" "$REPO_ROOT/.correctless/decisions" "decisions"

  # Migrate ARCHITECTURE.md (only if has Correctless markers)
  if [ -f "$REPO_ROOT/ARCHITECTURE.md" ] && [ ! -f "$REPO_ROOT/.correctless/ARCHITECTURE.md" ]; then
    if has_correctless_markers "$REPO_ROOT/ARCHITECTURE.md"; then
      mv "$REPO_ROOT/ARCHITECTURE.md" "$REPO_ROOT/.correctless/ARCHITECTURE.md"
      ok "Migrated ARCHITECTURE.md to .correctless/ (had Correctless markers)"
      migrated=true
    fi
  fi

  # Migrate AGENT_CONTEXT.md (only if has Correctless markers)
  if [ -f "$REPO_ROOT/AGENT_CONTEXT.md" ] && [ ! -f "$REPO_ROOT/.correctless/AGENT_CONTEXT.md" ]; then
    if has_correctless_markers "$REPO_ROOT/AGENT_CONTEXT.md"; then
      mv "$REPO_ROOT/AGENT_CONTEXT.md" "$REPO_ROOT/.correctless/AGENT_CONTEXT.md"
      ok "Migrated AGENT_CONTEXT.md to .correctless/ (had Correctless markers)"
      migrated=true
    fi
  fi

  # Migrate hooks to .correctless/hooks/ — only migrate hooks that exist in the
  # source distribution ($SCRIPT_DIR/hooks/). Custom user hooks are left in place.
  if [ -d "$REPO_ROOT/${_c}/hooks" ]; then
    mkdir -p "$REPO_ROOT/.correctless/hooks"
    for hook in "$REPO_ROOT/${_c}/hooks"/*.sh; do
      [ -f "$hook" ] || continue
      local bname_hook
      bname_hook="$(basename "$hook")"
      # Only migrate if this hook exists in the source distribution
      if [ -f "$SCRIPT_DIR/hooks/$bname_hook" ] && [ ! -f "$REPO_ROOT/.correctless/hooks/$bname_hook" ]; then
        mv "$hook" "$REPO_ROOT/.correctless/hooks/$bname_hook"
      fi
    done
    ok "Migrated Correctless hooks to .correctless/hooks/"
    migrated=true
  fi

  # Update CLAUDE.md path reference during migration (R-009)
  if [ -f "$REPO_ROOT/CLAUDE.md" ]; then
    if grep -q 'Read AGENT_CONTEXT\.md' "$REPO_ROOT/CLAUDE.md" 2>/dev/null && \
       ! grep -q 'Read \.correctless/AGENT_CONTEXT\.md' "$REPO_ROOT/CLAUDE.md" 2>/dev/null; then
      local tmp_cmd="$REPO_ROOT/CLAUDE.md.$$"
      sed 's|Read AGENT_CONTEXT\.md|Read .correctless/AGENT_CONTEXT.md|g' "$REPO_ROOT/CLAUDE.md" > "$tmp_cmd" \
        && mv "$tmp_cmd" "$REPO_ROOT/CLAUDE.md"
      ok "Updated CLAUDE.md to reference .correctless/AGENT_CONTEXT.md"
    fi
  fi

  # Update settings.json to reference new hook paths (R-018)
  if [ -f "$REPO_ROOT/${_c}/settings.json" ]; then
    if grep -q "${_c}/hooks/" "$REPO_ROOT/${_c}/settings.json" 2>/dev/null; then
      local tmp_settings="$REPO_ROOT/${_c}/settings.json.$$"
      sed -e "s|${_c}/hooks/|.correctless/hooks/|g" \
        "$REPO_ROOT/${_c}/settings.json" > "$tmp_settings" \
        && mv "$tmp_settings" "$REPO_ROOT/${_c}/settings.json"
      ok "Updated settings.json hook paths to .correctless/hooks/"
    fi
  fi

  # Clean up empty old directories (R-012)
  for dir in "$REPO_ROOT/${_c}/artifacts" "$REPO_ROOT/${_c}/hooks" "$REPO_ROOT/${_c}/meta" \
             "$REPO_ROOT/${_d}/specs" "$REPO_ROOT/${_d}/verification" "$REPO_ROOT/${_d}/decisions"; do
    if [ -d "$dir" ] && [ -z "$(ls -A "$dir" 2>/dev/null)" ]; then
      rmdir "$dir" 2>/dev/null || true
    fi
  done

  # Clean up .gitignore entries (R-013)
  if [ -f "$REPO_ROOT/.gitignore" ]; then
    if grep -q "${_c}/artifacts/" "$REPO_ROOT/.gitignore" 2>/dev/null; then
      local tmp_gi="$REPO_ROOT/.gitignore.$$"
      sed \
        -e '/^# Correctless.*transient/d' \
        -e "/^\.claude\/artifacts\/$/d" \
        "$REPO_ROOT/.gitignore" > "$tmp_gi" \
        && mv "$tmp_gi" "$REPO_ROOT/.gitignore"
    fi
  fi

  if [ "$migrated" = "true" ]; then
    ok "Migration complete"
  fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

echo ""
echo "Correctless — Setup"
echo "==================="
echo ""

# Check for jq — hooks require it (fail-fast, not warn)
if ! command -v jq >/dev/null 2>&1; then
  echo "ERROR: jq is required but not installed. All hooks depend on jq for JSON processing." >&2
  echo "  Install: brew install jq (macOS) / apt install jq (Debian) / pacman -S jq (Arch)" >&2
  exit 1
fi

# Detect language
DETECTED_LANG="$(detect_language)"
ok "Detected: $DETECTED_LANG project"

# Run migration before anything else — moves old artifacts to .correctless/
migrate_old_artifacts

# Create .correctless/ directory structure (R-001)
mkdir -p "$REPO_ROOT/.correctless/config" \
         "$REPO_ROOT/.correctless/hooks" \
         "$REPO_ROOT/.correctless/artifacts" \
         "$REPO_ROOT/.correctless/artifacts/research" \
         "$REPO_ROOT/.correctless/specs" \
         "$REPO_ROOT/.correctless/decisions" \
         "$REPO_ROOT/.correctless/verification" \
         "$REPO_ROOT/.correctless/learnings"
ok "Created .correctless/ directory structure"

# Check if config already exists and detect intensity level
CONFIG_DEST="$REPO_ROOT/.correctless/config/workflow-config.json"
HAS_INTENSITY="false"
if [ -f "$CONFIG_DEST" ]; then
  skip "workflow-config.json (already exists)"
  if jq -e '.workflow.intensity' "$CONFIG_DEST" >/dev/null 2>&1; then
    HAS_INTENSITY="true"
    ok "Intensity: $(jq -r '.workflow.intensity' "$CONFIG_DEST")"
  else
    ok "Intensity: standard (default)"
  fi
else
  MONO_TYPE="$(detect_monorepo_type)"
  if [ "$MONO_TYPE" != "none" ]; then
    ok "Monorepo detected: $MONO_TYPE"
    info "Per-package configuration will be set up by /csetup"
  fi

  mkdir -p "$(dirname "$CONFIG_DEST")"
  detect_config "$DETECTED_LANG" > "$CONFIG_DEST"
  ok "Generated workflow-config.json (standard intensity — add workflow.intensity for higher levels)"

  if [ "$MONO_TYPE" != "none" ] && command -v jq >/dev/null 2>&1 && [ -f "$CONFIG_DEST" ]; then
    jq '.is_monorepo = true' "$CONFIG_DEST" > "$CONFIG_DEST.$$" && mv "$CONFIG_DEST.$$" "$CONFIG_DEST"
  fi
fi

# Create ARCHITECTURE.md and AGENT_CONTEXT.md at .correctless/ (R-004)
create_if_missing "$REPO_ROOT/.correctless/ARCHITECTURE.md" "$SCRIPT_DIR/templates/ARCHITECTURE.md" "ARCHITECTURE.md"
create_if_missing "$REPO_ROOT/.correctless/AGENT_CONTEXT.md" "$SCRIPT_DIR/templates/AGENT_CONTEXT.md" "AGENT_CONTEXT.md"

# Create antipatterns.md at .correctless/ (R-005)
create_if_missing "$REPO_ROOT/.correctless/antipatterns.md" "$SCRIPT_DIR/templates/antipatterns.md" "antipatterns.md"

# Create preferences.md at .correctless/ (R-013 — semi-auto mode preferences)
create_if_missing "$REPO_ROOT/.correctless/preferences.md" "$SCRIPT_DIR/templates/preferences.md" "preferences.md"

# Create auto-policy.json at .correctless/config/ (INV-014 — Auto Mode Phase 2 policy)
if [ -f "$SCRIPT_DIR/templates/auto-policy.json" ]; then
  create_if_missing "$REPO_ROOT/.correctless/config/auto-policy.json" "$SCRIPT_DIR/templates/auto-policy.json" "auto-policy.json"
fi

# Record file state for the skill agent (template, existing, or missing→template)
ARCH_STATE="$(detect_file_state "$REPO_ROOT/.correctless/ARCHITECTURE.md")"
AGENT_STATE="$(detect_file_state "$REPO_ROOT/.correctless/AGENT_CONTEXT.md")"

if command -v jq >/dev/null 2>&1 && [ -f "$CONFIG_DEST" ]; then
  jq --arg a "$ARCH_STATE" --arg c "$AGENT_STATE" \
    '.setup = { architecture_state: $a, agent_context_state: $c }' \
    "$CONFIG_DEST" > "$CONFIG_DEST.$$" && mv "$CONFIG_DEST.$$" "$CONFIG_DEST"
  if [ "$ARCH_STATE" = "existing" ]; then
    info "ARCHITECTURE.md has real content — /csetup will offer to add Correctless sections"
  fi
  if [ "$AGENT_STATE" = "existing" ]; then
    info "AGENT_CONTEXT.md has real content — /csetup will offer to add Correctless sections"
  fi
fi

# Detect version file for /crelease (R-004, R-013)
detect_version_file "$CONFIG_DEST"

# Create .claude directory (still needed for settings.json)
mkdir -p "$REPO_ROOT/.claude"

# High+ intensity: create additional directories and meta files
if [ "$HAS_INTENSITY" = "true" ]; then
  mkdir -p "$REPO_ROOT/.correctless/meta"
  create_if_missing "$REPO_ROOT/.correctless/meta/workflow-effectiveness.json" "$SCRIPT_DIR/templates/workflow-effectiveness.json" "workflow-effectiveness.json"
  create_if_missing "$REPO_ROOT/.correctless/meta/drift-debt.json" "$SCRIPT_DIR/templates/drift-debt.json" "drift-debt.json"
  create_if_missing "$REPO_ROOT/.correctless/meta/external-review-history.json" "$SCRIPT_DIR/templates/external-review-history.json" "external-review-history.json"

  # Install invariant templates for high+ intensity projects
  mkdir -p "$REPO_ROOT/.correctless/templates/invariants"
  for inv_tmpl in "$SCRIPT_DIR/templates/invariants/"*.md; do
    [ -f "$inv_tmpl" ] || continue
    inv_name="$(basename "$inv_tmpl")"
    create_if_missing "$REPO_ROOT/.correctless/templates/invariants/$inv_name" "$inv_tmpl" "invariant template: $inv_name"
  done

  echo ""
  info "High-intensity tools:"
  detect_intensity_tools
fi

# Discover test patterns and existing tooling
discover_test_patterns "$CONFIG_DEST"
detect_existing_tools

# Install hooks to .correctless/hooks/ and register in settings
install_hooks
register_hooks

# Update CLAUDE.md
CLAUDEMD="$REPO_ROOT/CLAUDE.md"
if [ -f "$CLAUDEMD" ] && grep -q 'Correctless' "$CLAUDEMD" 2>/dev/null; then
  skip "CLAUDE.md already references Correctless"
else
  cat >> "$CLAUDEMD" <<'CMDEOF'

## Correctless

This project uses Correctless for structured development.
Read .correctless/AGENT_CONTEXT.md before starting any work.
Do NOT Read AGENT_CONTEXT.md from the project root — it may be stale or absent.
Available commands: /csetup, /cspec, /creview, /cmodel, /creview-spec, /ctdd, /cverify, /caudit, /cupdate-arch, /cdocs, /cpostmortem, /cdevadv, /credteam, /crefactor, /cpr-review, /ccontribute, /cmaintain, /cstatus, /csummary, /cmetrics, /cdebug, /chelp, /cwtf, /cquick, /crelease, /cexplain
CMDEOF
  ok "Updated CLAUDE.md"
fi

# Add Correctless Learnings section if not present
if [ -f "$CLAUDEMD" ] && ! grep -q 'Correctless Learnings' "$CLAUDEMD" 2>/dev/null; then
  cat >> "$CLAUDEMD" <<'LEARNEOF'

## Correctless Learnings
<!-- Auto-updated by Correctless workflow. Do not edit above this line. -->
LEARNEOF
  ok "Added Correctless Learnings section to CLAUDE.md"
fi

echo ""
echo "Created:"
echo "  .correctless/config/workflow-config.json  <- review and adjust"
if [ "$ARCH_STATE" = "template" ]; then
  echo "  .correctless/ARCHITECTURE.md               <- /csetup will populate from your codebase"
else
  echo "  .correctless/ARCHITECTURE.md               <- /csetup will offer Correctless sections"
fi
if [ "$AGENT_STATE" = "template" ]; then
  echo "  .correctless/AGENT_CONTEXT.md              <- /csetup will populate from your codebase"
else
  echo "  .correctless/AGENT_CONTEXT.md              <- /csetup will offer Correctless sections"
fi
if [ "$HAS_INTENSITY" = "true" ]; then
  echo "  .correctless/meta/                         <- workflow learning data"
fi
echo ""
echo "Next steps:"
echo "  1. Run /csetup to complete interactive setup (config review, project discovery, health check)"
echo "     Note: On existing projects, this takes a few minutes — the agent is learning your codebase."
if [ "$HAS_INTENSITY" != "true" ]; then
  echo "     To increase intensity: add \"intensity\": \"high\" or \"critical\" to workflow section"
fi
echo "  2. Try it: git checkout -b feature/my-feature, then run /cspec"
echo ""
